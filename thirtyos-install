# ── Command: setup ─────────────────────────────────────────
cmd_setup() {
    check_root "setup"
    show_banner
    echo -e "${BOLD}=== First-Time Setup ThirtyOS ===${NC}"
    echo ""

    # Hostname
    ask "Masukkan hostname (default: thirtyos):"
    read -r NEW_HOSTNAME
    NEW_HOSTNAME="${NEW_HOSTNAME:-thirtyos}"
    hostnamectl set-hostname "$NEW_HOSTNAME"
    sed -i "s/127.0.1.1.*/127.0.1.1\t${NEW_HOSTNAME}/" /etc/hosts 2>/dev/null || \
        echo "127.0.1.1 ${NEW_HOSTNAME}" >> /etc/hosts
    log "Hostname diset ke: $NEW_HOSTNAME"

    # Timezone
    ask "Timezone (default: Asia/Jakarta):"
    read -r TZ_INPUT
    TZ_INPUT="${TZ_INPUT:-Asia/Jakarta}"
    timedatectl set-timezone "$TZ_INPUT" 2>/dev/null || \
        ln -sf "/usr/share/zoneinfo/${TZ_INPUT}" /etc/localtime
    log "Timezone: $TZ_INPUT"

    # Buat user baru
    ask "Buat user baru? (y/N):"
    read -r CREATE_USER
    if [[ "$CREATE_USER" =~ ^[Yy]$ ]]; then
        ask "Nama user:"
        read -r NEW_USER
        if [[ -n "$NEW_USER" ]]; then
            useradd -m -s /bin/bash "$NEW_USER" 2>/dev/null || true
            usermod -aG sudo,docker "$NEW_USER" 2>/dev/null || true
            passwd "$NEW_USER"
            log "User $NEW_USER dibuat"
        fi
    fi

    # Static IP
    ask "Setup static IP? (y/N):"
    read -r STATIC_IP
    if [[ "$STATIC_IP" =~ ^[Yy]$ ]]; then
        IFACE=$(ip route | grep default | awk '{print $5}' | head -1)
        [[ -z "$IFACE" ]] && IFACE=$(ls /sys/class/net | grep -v lo | grep -v docker | head -1)
        [[ -z "$IFACE" ]] && IFACE="eth0"
        ask "Interface (detected: $IFACE):"
        read -r IFACE_INPUT
        IFACE="${IFACE_INPUT:-$IFACE}"
        ask "IP Address (contoh: 192.168.1.100/24):"
        read -r IP_ADDR
        ask "Gateway (contoh: 192.168.1.1):"
        read -r GATEWAY
        ask "DNS (default: 8.8.8.8):"
        read -r DNS
        DNS="${DNS:-8.8.8.8}"

        if [[ -z "$IP_ADDR" || -z "$GATEWAY" ]]; then
            warn "IP Address dan Gateway wajib diisi. Static IP dibatalkan."
        elif [[ ! "$IFACE" =~ ^[a-zA-Z0-9._-]{2,20}$ ]]; then
            warn "Nama interface tidak valid: $IFACE. Static IP dibatalkan."
        else
            # Hapus netplan config kalo ada (biar gak conflict)
            rm -f /etc/netplan/01-thirtyos-static.yaml 2>/dev/null || true
            # Pake NM connection profile
            UUID=$(uuidgen 2>/dev/null || echo "thirty-$(date +%s)")
            cat > "/etc/NetworkManager/system-connections/${IFACE}.nmconnection" << NMPROFILE
[connection]
id=${IFACE}
uuid=${UUID}
type=ethernet
interface-name=${IFACE}
autoconnect=true

[ipv4]
method=manual
addresses=${IP_ADDR}
gateway=${GATEWAY}
dns=${DNS};1.1.1.1;

[ipv6]
method=disabled
NMPROFILE
            chmod 600 /etc/NetworkManager/system-connections/${IFACE}.nmconnection
            systemctl restart NetworkManager 2>/dev/null || true
            log "Static IP dikonfigurasi: $IP_ADDR via $GATEWAY"
        fi
    fi

    # ZRAM
    info "Mengaktifkan ZRAM swap..."
    if ! grep -q zram /proc/swaps 2>/dev/null; then
        modprobe zram 2>/dev/null || true
        echo lz4 > /sys/block/zram0/comp_algorithm 2>/dev/null || true
        total=$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
        [[ "$total" -gt 0 ]] && size=$((total * 50 / 100 * 1024)) || size=512M
        echo "$size" > /sys/block/zram0/disksize 2>/dev/null || true
        mkswap /dev/zram0 2>/dev/null || true
        swapon /dev/zram0 2>/dev/null || true
        log "ZRAM swap aktif (50% RAM)"
    else
        log "ZRAM swap sudah aktif"
    fi

    echo ""
    log "${BOLD}Setup selesai! Reboot disarankan: sudo reboot${NC}"
}

# ── Command: bot-wa ────────────────────────────────────────
cmd_botwa() {
    check_root "bot-wa"
    BOT_DIR="/opt/bot-wa"
    BOT_REPO="https://github.com/ahdikhfDev/bot-wa"

    show_banner
    echo -e "${BOLD}=== WhatsApp Bot Installer ===${NC}"
    echo ""

    # Cek apakah sudah ada
    if [[ -d "$BOT_DIR" ]]; then
        ask "Bot sudah terinstall. Update? (y/N):"
        read -r DO_UPDATE
        if [[ "$DO_UPDATE" =~ ^[Yy]$ ]]; then
            info "Menghentikan bot..."
            pm2 stop bot-wa 2>/dev/null || true
            info "Update dari GitHub..."
            cd "$BOT_DIR" && git pull
            npm install --omit=dev
            pm2 restart bot-wa 2>/dev/null || true
            log "Bot berhasil diupdate!"
        fi
        return
    fi

    # Install baru
    info "Mengecek Node.js..."
    if ! command -v node &>/dev/null; then
        info "Menginstall Node.js..."
        curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
        apt-get install -y nodejs
    fi
    log "Node.js: $(node -v)"

    info "Mengecek PM2..."
    if ! command -v pm2 &>/dev/null; then
        npm install -g pm2
    fi
    log "PM2: $(pm2 -v)"

    info "Clone repository bot-wa..."
    git clone --depth=1 "$BOT_REPO" "$BOT_DIR"
    cd "$BOT_DIR"

    # Konfigurasi
    if [[ -f "$BOT_DIR/.env.example" ]]; then
        cp "$BOT_DIR/.env.example" "$BOT_DIR/.env"
        ask "Edit konfigurasi bot sekarang? (y/N):"
        read -r EDIT_ENV
        [[ "$EDIT_ENV" =~ ^[Yy]$ ]] && nano "$BOT_DIR/.env"
    fi

    # Install dependencies (termasuk express untuk web dashboard)
    info "Install dependencies..."
    cd "$BOT_DIR" && npm install --omit=dev

    # Jalankan
    ask "Jalankan bot sekarang? (Y/n):"
    read -r RUN_NOW
    if [[ ! "$RUN_NOW" =~ ^[Nn]$ ]]; then
        cd "$BOT_DIR"

        pm2 start "src/index.js" --name "bot-wa" \
            --restart-delay=5000 \
            --max-restarts=10 \
            --log /root/.pm2/logs/bot-wa.log

        pm2 save
        pm2 startup systemd -u root --hp /root 2>/dev/null || true

        echo ""
        info "Bot berjalan. Scan QR di bawah ini:"
        echo ""
        sleep 2
        pm2 logs bot-wa --lines 30 --nostream 2>/dev/null || \
            info "Gunakan: pm2 logs bot-wa"
    fi

    echo ""
    log "Bot WA berhasil diinstall!"
    LOCAL_IP=$(hostname -I | awk '{print $1}')
    echo ""
    info "Web Dashboard: ${CYAN}http://${LOCAL_IP}:6789${NC}"
    echo "  Login password default: ${YELLOW}12345678${NC}"
    echo "  Manage skills, whitelist, API keys, settings, ganti password"
    echo ""
    info "Commands:"
    echo "  pm2 logs bot-wa         → lihat log + QR code"
    echo "  pm2 restart bot-wa      → restart bot"
    echo "  pm2 stop bot-wa         → stop bot"
    echo "  http://<ip>:6789        → Web Dashboard"
}

# ── Command: tunnel ────────────────────────────────────────
cmd_tunnel() {
    check_root "tunnel"
    show_banner
    echo -e "${BOLD}=== Cloudflare Tunnel Setup ===${NC}"
    echo ""

    if ! command -v cloudflared &>/dev/null; then
        info "Menginstall cloudflared..."
        ARCH=$(dpkg --print-architecture)
        wget -q "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${ARCH}.deb" \
            -O /tmp/cloudflared.deb
        dpkg -i /tmp/cloudflared.deb
        rm /tmp/cloudflared.deb
        log "cloudflared terinstall"
    else
        log "cloudflared sudah ada: $(cloudflared --version)"
    fi

    ask "Login ke Cloudflare sekarang? (Y/n):"
    read -r DO_LOGIN
    if [[ ! "$DO_LOGIN" =~ ^[Nn]$ ]]; then
        cloudflared tunnel login
    fi

    ask "Nama tunnel (contoh: thirtyos-home):"
    read -r TUNNEL_NAME
    TUNNEL_NAME="${TUNNEL_NAME:-thirtyos-home}"

    ask "Buat tunnel baru? (Y/n):"
    read -r CREATE_TUNNEL
    if [[ ! "$CREATE_TUNNEL" =~ ^[Nn]$ ]]; then
        cloudflared tunnel create "$TUNNEL_NAME"
    fi

    ask "Port lokal yang mau di-expose (contoh: 80):"
    read -r LOCAL_PORT
    LOCAL_PORT="${LOCAL_PORT:-80}"

    ask "Subdomain kamu (contoh: home.namadomain.com):"
    read -r SUBDOMAIN

    # Buat config
    TUNNEL_ID=$(cloudflared tunnel list | grep "$TUNNEL_NAME" | awk '{print $1}')
    mkdir -p ~/.cloudflared

    cat > ~/.cloudflared/config.yml << CF_CONFIG
tunnel: ${TUNNEL_ID}
credentials-file: /root/.cloudflared/${TUNNEL_ID}.json

ingress:
  - hostname: ${SUBDOMAIN}
    service: http://localhost:${LOCAL_PORT}
  - service: http_status:404
CF_CONFIG

    # Route DNS
    [[ -n "$SUBDOMAIN" ]] && cloudflared tunnel route dns "$TUNNEL_NAME" "$SUBDOMAIN" 2>/dev/null || true

    # Service
    cloudflared service install 2>/dev/null || true
    systemctl enable --now cloudflared 2>/dev/null || true

    log "Tunnel aktif! Akses via: https://${SUBDOMAIN}"
}

# ── Command: panel ─────────────────────────────────────────
cmd_panel() {
    check_root "panel"
    show_banner
    echo -e "${BOLD}=== Web Panel Installer ===${NC}"
    echo ""
    echo -e "  ${GREEN}1)${NC} CasaOS  — Dashboard lengkap, app store"
    echo -e "  ${GREEN}2)${NC} Portainer — Docker UI manager"
    echo ""
    ask "Pilih (1/2):"
    read -r PANEL_CHOICE

    case "$PANEL_CHOICE" in
        1)
            info "Menginstall CasaOS..."
            if ! command -v docker &>/dev/null; then
                warn "Docker belum ada, install dulu..."
                curl -fsSL https://get.docker.com | sh
            fi
            curl -fsSL https://get.casaos.io | bash
            log "CasaOS terinstall! Akses: http://$(hostname -I | awk '{print $1}')"
            ;;
        2)
            info "Menginstall Portainer..."
            if ! command -v docker &>/dev/null; then
                warn "Docker belum ada, install dulu..."
                curl -fsSL https://get.docker.com | sh
            fi
            docker volume create portainer_data 2>/dev/null || true
            docker run -d \
                --name portainer \
                --restart=always \
                -p 9000:9000 \
                -v /var/run/docker.sock:/var/run/docker.sock \
                -v portainer_data:/data \
                portainer/portainer-ce:latest
            log "Portainer terinstall! Akses: http://$(hostname -I | awk '{print $1}'):9000"
            ;;
        *)
            err "Pilihan tidak valid"
            ;;
    esac
}

# ── Command: media ─────────────────────────────────────────
cmd_media() {
    check_root "media"
    show_banner
    echo -e "${BOLD}=== Homeflix Installer ===${NC}"
    echo ""

    if ! command -v docker &>/dev/null; then
        warn "Docker belum ada, install dulu..."
        curl -fsSL https://get.docker.com | sh
        systemctl enable --now docker
    fi

    ask "Path folder media kamu (default: /opt/media):"
    read -r MEDIA_PATH
    MEDIA_PATH="${MEDIA_PATH:-/opt/media}"
    mkdir -p "$MEDIA_PATH"

    info "Menjalankan Homeflix via Docker..."
    docker run -d \
        --name homeflix \
        --restart=always \
        -p 4000:4000 \
        -v "${MEDIA_PATH}:/movies" \
        xebadir/homeflix:latest 2>/dev/null || \
    docker start homeflix 2>/dev/null || \
    warn "Cek image Homeflix terbaru di Docker Hub"

    log "Homeflix berjalan! Akses: http://$(hostname -I | awk '{print $1}'):4000"
}

# ── Command: retro ─────────────────────────────────────────
cmd_retro() {
    check_root "retro"
    show_banner
    echo -e "${BOLD}=== RetroArch Installer ===${NC}"
    echo ""

    info "Menginstall RetroArch..."
    apt-get update -qq
    apt-get install -y retroarch 2>/dev/null || {
        # PPA fallback
        add-apt-repository ppa:libretro/stable -y 2>/dev/null || true
        apt-get update -qq
        apt-get install -y retroarch
    }

    info "Menginstall core emulator populer..."
    apt-get install -y \
        libretro-snes9x \
        libretro-mgba \
        libretro-nestopia \
        libretro-mupen64plus 2>/dev/null || \
    warn "Beberapa core mungkin tidak tersedia, download manual via RetroArch"

    log "RetroArch terinstall!"
    info "Jalankan: retroarch"
    info "Atau tambah ke PM2: pm2 start retroarch --name retro"
}

# ── Command: update ────────────────────────────────────────
cmd_update() {
    check_root "update"
    show_banner
    echo -e "${BOLD}=== Update ThirtyOS ===${NC}"
    echo ""

    info "Update sistem..."
    ask "Jalankan apt upgrade? (y/N):"
    read -r DO_UPGRADE
    if [[ "$DO_UPGRADE" =~ ^[Yy]$ ]]; then
        apt-get update -qq && apt-get upgrade -y
        log "Sistem terupdate"
    else
        info "apt upgrade dilewati"
    fi

    info "Update npm global packages..."
    npm update -g 2>/dev/null || true
    log "NPM packages terupdate"

    info "Update bot-wa..."
    if [[ -d /opt/bot-wa ]]; then
        ask "Update bot-wa? (y/N):"
        read -r UPDATE_BOTWA
        if [[ "$UPDATE_BOTWA" =~ ^[Yy]$ ]]; then
            pm2 stop bot-wa 2>/dev/null || true
            cd /opt/bot-wa && git pull && npm install --omit=dev
            pm2 restart bot-wa 2>/dev/null || true
            log "bot-wa terupdate"
        else
            info "bot-wa tidak diupdate"
        fi
    else
        warn "bot-wa belum diinstall, skip"
    fi

    info "Update thirtyos-install..."
    curl -fsSL https://raw.githubusercontent.com/ahdikhfDev/ThirtyOS-tools/main/thirtyos-install \
        -o /usr/local/bin/thirtyos-install && chmod +x /usr/local/bin/thirtyos-install
    log "thirtyos-install terupdate"

    info "Aktifkan MOTD di SSH..."
    if grep -q "^PrintMotd no" /etc/ssh/sshd_config; then
        sed -i 's/^PrintMotd no/PrintMotd yes/' /etc/ssh/sshd_config
        log "PrintMotd diaktifkan"
    else
        log "PrintMotd sudah aktif"
    fi
    # Matikan PAM motd biar gak dobel
    if grep -q "^session    optional     pam_motd.so" /etc/pam.d/sshd; then
        sed -i 's/^session    optional     pam_motd.so/#session    optional     pam_motd.so/' /etc/pam.d/sshd
        log "PAM motd dinonaktifkan"
    fi
    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null || true

    info "Update MOTD banner..."
    cat > /etc/update-motd.d/00-thirtyos << 'MOTDEOF'
#!/bin/bash

c_art='\033[38;5;51m'
c_sep='\033[1;30m'
c_lbl='\033[38;5;39m'
c_val='\033[0m'
c_warn='\033[38;5;214m'
c_rst='\033[0m'

os_val=$(grep -m1 'PRETTY_NAME' /etc/os-release | cut -d= -f2 | tr -d '"')
[ -z "$os_val" ] && os_val="Armbian 26.2.1 noble"
host_val=$(hostname)
ip_val=$(hostname -I | awk '{print $1}')
up_val=$(uptime -p | sed 's/up //')
ram_val=$(free -m | awk '/Mem/{printf "%dMB / %dMB", $3, $2}')
disk_val=$(df -h / | awk 'NR==2 {printf "%s / %s (%s)", $3, $2, $5}')
cpu_val="4xCortex-A53"

echo ""
printf "${c_art}%-48s${c_sep}│  ${c_lbl}%-5s: ${c_val}%s\n" '   __  __    _      __           ____  _____ ' 'OS' "$os_val"
printf "${c_art}%-48s${c_sep}│  ${c_lbl}%-5s: ${c_val}%s\n" '  / /_/ /_  (_)____/ /_ __  __  / __ \/ ___/ ' 'Host' "${host_val} (${ip_val})"
printf "${c_art}%-48s${c_sep}│  ${c_lbl}%-5s: ${c_val}%s\n" ' / __/ __ \/ / ___/ __// / / / / / / /\__ \  ' 'Up' "$up_val"
printf "${c_art}%-48s${c_sep}│  ${c_lbl}%-5s: ${c_val}%s\n" '/ /_/ / / / / /  / /_ / /_/ / / /_/ /___/ /  ' 'RAM' "$ram_val"
printf "${c_art}%-48s${c_sep}│  ${c_lbl}%-5s: ${c_val}%s\n" '\__/_/ /_/_/_/   \__/ \__, /  \____//____/   ' 'Disk' "$disk_val"
printf "${c_art}%-48s${c_sep}│  ${c_lbl}%-5s: ${c_val}%s\n" '                     /____/                  ' 'CPU' "$cpu_val"
echo ""
echo -e "  ${c_warn}Jalankan 'thirtyos-install' untuk setup layanan.${c_rst}"
echo ""
MOTDEOF
    chmod +x /etc/update-motd.d/00-thirtyos
    bash /etc/update-motd.d/00-thirtyos | tee /etc/motd > /dev/null
    log "MOTD banner terupdate"

    info "Setup systemd service regenerate MOTD tiap boot..."
    cat > /etc/systemd/system/thirtyos-motd.service << 'SVC'
[Unit]
Description=Regenerate ThirtyOS MOTD at boot
After=network.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c '/etc/update-motd.d/00-thirtyos | tee /etc/motd > /dev/null'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SVC
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable thirtyos-motd.service 2>/dev/null || true
    log "MOTD systemd service aktif"

    info "Setup ZRAM boot service..."
    cat > /etc/systemd/system/zram-swap.service << 'ZRAMSVC'
[Unit]
Description=ZRAM swap setup
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'if ! grep -q zram /proc/swaps 2>/dev/null; then modprobe zram 2>/dev/null; echo lz4 > /sys/block/zram0/comp_algorithm 2>/dev/null; total=$(awk "/MemTotal/{print \$2}" /proc/meminfo 2>/dev/null || echo 0); [ "$total" -gt 0 ] && size=$((total * 50 / 100 * 1024)) || size=512M; echo "$size" > /sys/block/zram0/disksize 2>/dev/null; mkswap /dev/zram0 2>/dev/null; swapon /dev/zram0 2>/dev/null; fi'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
ZRAMSVC
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable zram-swap.service 2>/dev/null || true
    log "ZRAM boot service aktif"

    log "Update selesai!"
}

# ── Command: status ────────────────────────────────────────
cmd_status() {
    show_banner
    echo -e "${BOLD}=== Status ThirtyOS ===${NC}"
    echo ""

    # Info sistem
    echo -e "${CYAN}── Sistem ────────────────────────────${NC}"
    echo -e "  Hostname  : $(hostname)"
    echo -e "  IP        : $(hostname -I | tr ' ' '\n' | grep -v '^$' | head -3 | tr '\n' ' ')"
    echo -e "  Uptime    : $(uptime -p)"
    echo -e "  RAM       : $(free -m | awk '/Mem/{printf "%dMB used / %dMB total", $3, $2}')"
    echo -e "  ZRAM      : $(zramctl 2>/dev/null | grep -v NAME | awk '{print $5}' | head -1 || echo 'N/A')"
    DISK=$(df -h / | awk 'NR==2{printf "%s used / %s total", $3, $2}')
    echo -e "  Disk      : $DISK"
    echo ""

    # PM2 services
    echo -e "${CYAN}── PM2 Services ──────────────────────${NC}"
    if command -v pm2 &>/dev/null; then
        pm2 list 2>/dev/null || echo "  Tidak ada service PM2"
    else
        echo "  PM2 belum diinstall"
    fi
    echo ""

    # Docker containers
    echo -e "${CYAN}── Docker Containers ─────────────────${NC}"
    if command -v docker &>/dev/null; then
        docker ps --format "  {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || \
