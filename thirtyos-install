        fi
    fi

    # Pastikan opencode config valid (jangan hapus, cek dulu)
    OC_USER="${SUDO_USER:-${USER}}"
    OC_HOME=$(eval echo ~$OC_USER)
    OC_CONFIG_DIR="$OC_HOME/.config/opencode"
    OC_CONFIG="$OC_CONFIG_DIR/config.json"
    if [[ -f "$OC_CONFIG" ]]; then
        if command -v jq &>/dev/null && ! jq empty "$OC_CONFIG" 2>/dev/null; then
            warn "config.json corrupt — rebuild default"
            echo '{"model": "opencode-free"}' > "$OC_CONFIG"
        fi
    else
        mkdir -p "$OC_CONFIG_DIR"
        echo '{"model": "opencode-free"}' > "$OC_CONFIG"
    fi

    # Port & password
    OC_PORT="${OC_PORT:-4096}"
    OC_PASS_FILE="/etc/opencode-web.pass"
    if [[ -z "${OC_PASS}" && -f "$OC_PASS_FILE" ]]; then
        OC_PASS=$(cat "$OC_PASS_FILE")
    fi
    OC_PASS="${OC_PASS:-$(openssl rand -hex 8)}"
    echo "$OC_PASS" > "$OC_PASS_FILE"
    chmod 600 "$OC_PASS_FILE"

    # Buat systemd service untuk opencode serve
    cat > /etc/systemd/system/opencode-web.service << OCSVC
[Unit]
Description=OpenCode Web Interface
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/opencode serve --port ${OC_PORT} --hostname 0.0.0.0 --print-logs
Restart=on-failure
RestartSec=5
User=${OC_USER}
Environment=OPENCODE_SERVER_PASSWORD=${OC_PASS}
Environment=TMPDIR=/var/tmp
Environment=HOME=${OC_HOME}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
OCSVC

    systemctl daemon-reload
    systemctl enable --now opencode-web

    # Cek service
    sleep 5
    if curl -sI http://localhost:${OC_PORT} 2>/dev/null | grep -q "401\|200"; then
        log "OpenCode Web berjalan di port ${OC_PORT}"
    else
        warn "OpenCode Web mungkin belum siap, cek: systemctl status opencode-web"
    fi

    LOCAL_IP=$(hostname -I | awk '{print $1}')
    echo ""
    log "${BOLD}OpenCode siap diakses via browser!${NC}"
    echo -e "  Local   : ${CYAN}http://${LOCAL_IP}:${OC_PORT}${NC}"
    echo -e "  Username: ${GREEN}opencode${NC}"
    echo -e "  Password: ${GREEN}${OC_PASS}${NC}"
    echo ""
    echo -e "  ${YELLOW}Tunnel:${NC} thirtyos-install ai tunnel (port 4096)"
    echo ""
}

cmd_ai_update() {
    check_root "ai"
    show_banner
    echo -e "${BOLD}=== AI Service Update ===${NC}"
    echo ""

    info "Update 9Router..."
    npm update -g 9router 2>/dev/null || true
    log "9Router diupdate"

    info "Update OpenCode..."
    rm -f /usr/local/bin/opencode 2>/dev/null || true
    TMPDIR=/var/tmp curl -fsSL https://opencode.ai/install | bash 2>&1 || \
        cmd_install_opencode_binary
    log "OpenCode diupdate"

    info "Pre-build native modules 9Router..."
    TMPDIR=/var/tmp npm install -g better-sqlite3 2>&1 || true
    systemctl restart 9router 2>/dev/null || true
    log "9Router native modules siap"

    info "Restart OpenCode Web..."
    systemctl restart opencode-web 2>/dev/null || true
    log "OpenCode Web di-restart"

    log "${BOLD}AI services update selesai!${NC}"
}

cmd_ai_tunnel() {
    check_root "ai"
    show_banner
    echo -e "${BOLD}=== Expose AI via Cloudflare Tunnel ===${NC}"
    echo ""

    if ! command -v cloudflared &>/dev/null; then
        info "Menginstall cloudflared..."
        ARCH=$(dpkg --print-architecture)
        wget -q "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${ARCH}.deb" \
            -O /tmp/cloudflared.deb 2>/dev/null || true
        dpkg -i /tmp/cloudflared.deb 2>/dev/null || true
        rm /tmp/cloudflared.deb 2>/dev/null || true
    fi

    echo -e "  Buat tunnel untuk akses AI services dari luar."
    echo -e "  Port yang di-expose via subdomain:"
    echo -e "    ${GREEN}20128${NC} — 9Router Dashboard + API (ai.domain.com)"
    echo -e "    ${GREEN}4096${NC}  — OpenCode Web UI (opencode.domain.com)"
    echo ""
    ask "Domain utama (contoh: ai.namadomain.com):"
    read -r AI_DOMAIN
    [[ -n "$AI_DOMAIN" ]] && OC_DOMAIN="opencode.${AI_DOMAIN#*.}" || OC_DOMAIN=""

    ask "Login Cloudflare dulu? (Y/n):"
    read -r CF_LOGIN
    if [[ ! "$CF_LOGIN" =~ ^[Nn]$ ]]; then
        cloudflared tunnel login
    fi

    TUNNEL_NAME="thirtyos-ai"
    cloudflared tunnel create "$TUNNEL_NAME" 2>/dev/null || true
    TUNNEL_ID=$(cloudflared tunnel list 2>/dev/null | grep "$TUNNEL_NAME" | awk '{print $1}' | head -1)

    mkdir -p ~/.cloudflared
    cat > ~/.cloudflared/config-ai.yml << CFG
tunnel: ${TUNNEL_ID}
credentials-file: /root/.cloudflared/${TUNNEL_ID}.json

ingress:
  - hostname: ${AI_DOMAIN}
    service: http://localhost:20128
  - hostname: ${OC_DOMAIN}
    service: http://localhost:4096
  - service: http_status:404
CFG

    [[ -n "$AI_DOMAIN" ]] && cloudflared tunnel route dns "$TUNNEL_NAME" "$AI_DOMAIN" 2>/dev/null || true
    [[ -n "$OC_DOMAIN" ]] && cloudflared tunnel route dns "$TUNNEL_NAME" "$OC_DOMAIN" 2>/dev/null || true

    # Jalankan sebagai service terpisah
    cat > /etc/systemd/system/cloudflared-ai.service << SVC
[Unit]
Description=Cloudflare Tunnel - AI
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/cloudflared tunnel --config /root/.cloudflared/config-ai.yml run
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
SVC
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable --now cloudflared-ai 2>/dev/null || true

    log "AI Tunnel aktif!"
    info "9Router  : https://${AI_DOMAIN}"
    info "OpenCode : https://${OC_DOMAIN} (user: opencode / pass: thirtyos)"
}

# ── Main ───────────────────────────────────────────────────
case "${1:-help}" in
    setup)     cmd_setup ;;
    ai)        cmd_ai "$@" ;;
    bot-wa)    cmd_botwa ;;
    tunnel)    cmd_tunnel ;;
    panel)     cmd_panel ;;
    media)     cmd_media ;;
    retro)     cmd_retro ;;
    wifi)      cmd_wifi ;;
    optimize)  cmd_optimize ;;
    prepare)   cmd_prepare ;;
    update)    cmd_update ;;
    status)    cmd_status ;;
    uninstall) cmd_uninstall ;;
    version)   cmd_version ;;
    help|--help|-h) show_help ;;
    *)
        err "Command tidak dikenal: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
