}

# ── Command: prepare ─────────────────────────────────────
cmd_prepare() {
    check_root "prepare"
    show_banner
    echo -e "${BOLD}=== First-Boot Preparation ===${NC}"
    echo ""

    info "Update package list..."
    apt-get update -qq || true

    info "Install Node.js & npm..."
    if ! command -v node &>/dev/null; then
        curl -fsSL https://deb.nodesource.com/setup_20.x | bash - 2>/dev/null || true
        apt-get install -y nodejs 2>/dev/null || true
    fi
    if command -v node &>/dev/null; then
        log "Node.js: $(node -v)"
        info "Install PM2..."
        npm install -g pm2 2>/dev/null || true
    fi

    info "Install Docker..."
    if ! command -v docker &>/dev/null; then
        curl -fsSL https://get.docker.com | sh 2>/dev/null || true
        systemctl enable --now docker 2>/dev/null || true
    fi
    if command -v docker &>/dev/null; then
        log "Docker: $(docker --version)"
    fi

    info "Install system packages..."
    apt-get install -y --no-install-recommends \
        nano htop \
        zram-tools \
        unzip zip \
        net-tools \
        jq 2>/dev/null || true

    info "Setup ZRAM..."
    systemctl enable --now zramswap 2>/dev/null || true

    info "Clone bot-wa..."
    if [[ ! -d /opt/bot-wa ]]; then
        git clone --depth=1 https://github.com/ahdikhfDev/bot-wa /opt/bot-wa 2>/dev/null || true
    fi
    if [[ -d /opt/bot-wa ]]; then
        cd /opt/bot-wa && npm install --omit=dev 2>/dev/null || true
    fi

    # Setup log rotation
    cat > /etc/logrotate.d/thirtyos << 'LOGROTATE'
/root/.pm2/logs/*.log {
    daily
    rotate 3
    compress
    missingok
    notifempty
    copytruncate
}
LOGROTATE

    # PM2 startup
    pm2 startup systemd -u root --hp /root 2>/dev/null || true

    # Cleanup
    apt-get clean 2>/dev/null || true
    apt-get autoremove -y 2>/dev/null || true

    echo ""
    log "${BOLD}Selesai! Semua package sudah terinstall.${NC}"
}

# ── Command: wifi ──────────────────────────────────────────
cmd_wifi() {
    check_root "wifi"
    show_banner
    echo -e "${BOLD}=== WiFi Manager ===${NC}"
    echo ""

    # Cek NetworkManager
    if command -v nmcli &>/dev/null; then
        WIFI_IFACE=$(nmcli device status 2>/dev/null | grep wifi | awk '{print $1}' | head -1)
        if [[ -z "$WIFI_IFACE" ]]; then
            err "Tidak ada adapter WiFi terdeteksi"
        fi
        log "Adapter WiFi: $WIFI_IFACE"

        echo ""
        ask "Pilih aksi (1: scan & connect, 2: disconnect, 3: status):"
        read -r WIFI_ACTION

        case "$WIFI_ACTION" in
            1)
                info "Scanning jaringan..."
                nmcli device wifi list "$WIFI_IFACE" 2>/dev/null || nmcli device wifi list
                echo ""
                ask "Nama SSID:"
                read -r SSID
                ask "Password (kosongin kalo open):"
                read -rs PASSWORD
                echo ""
                if [[ -z "$PASSWORD" ]]; then
                    nmcli device wifi connect "$SSID" iface "$WIFI_IFACE"
                else
                    nmcli device wifi connect "$SSID" password "$PASSWORD" iface "$WIFI_IFACE"
                fi
                if [[ $? -eq 0 ]]; then
                    log "Terhubung ke $SSID"
                    info "IP: $(nmcli -t -f IP4.ADDRESS dev show "$WIFI_IFACE" 2>/dev/null | head -1)"
                else
                    err "Gagal connect ke $SSID"
                fi
                ;;
            2)
                ask "Nama SSID yang mau di-disconnect:"
                read -r SSID
                nmcli connection down id "$SSID" 2>/dev/null || \
                    nmcli device disconnect "$WIFI_IFACE"
                log "Disconnected"
                ;;
            3)
                nmcli device status
                echo ""
                nmcli connection show --active
                ;;
        esac

    elif command -v iwctl &>/dev/null; then
        iwctl
    elif command -v wpa_cli &>/dev/null; then
        warn "NetworkManager tidak terinstall, pakai wpa_supplicant manual"
        info "Lihat jaringan: sudo iw dev wlan0 scan | grep SSID"
        ask "SSID:"
        read -r SSID
        ask "Password:"
        read -rs PASSWORD
        echo ""
        wpa_passphrase "$SSID" "$PASSWORD" >> /etc/wpa_supplicant/wpa_supplicant.conf
        wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant/wpa_supplicant.conf
        dhclient wlan0
        log "Terhubung ke $SSID"
    else
        err "Tidak ada WiFi manager (nmcli/iwctl/wpa_supplicant). Install: apt install network-manager"
    fi
}

# ── Command: optimize ──────────────────────────────────────
cmd_optimize() {
    check_root "optimize"
    show_banner
    echo -e "${BOLD}=== ThirtyOS Optimizer ===${NC}"
    echo ""

    echo -e "  ${GREEN}1)${NC} Optimasi semua (recommended)"
    echo -e "  ${GREEN}2)${NC} Custom — pilih manual"
    echo ""
    ask "Pilih (1/2):"
    read -r OPT_CHOICE

    do_optimize_all() {
        echo ""

        info "1/8 — Fix & aktifkan ZRAM swap..."
        if ! lsmod | grep -q zram; then
            modprobe zram 2>/dev/null || true
        fi
        if ! command -v zramswap &>/dev/null; then
            apt-get install -y zram-tools 2>/dev/null || true
        fi
        if [[ -f /etc/default/zramswap ]]; then
            systemctl enable --now zramswap 2>/dev/null || true
        fi
        sleep 1
        if zramctl 2>/dev/null | grep -q zram; then
            log "ZRAM: $(zramctl 2>/dev/null | grep -v NAME | awk '{print $3, "/", $2}')"
        else
            warn "ZRAM gagal, cek: dmesg | grep zram"
        fi

        info "2/8 — Matikan journal persistent (log di RAM)..."
        journalctl --vacuum-size=10M 2>/dev/null || true
        cat > /etc/systemd/journald.conf << 'JOURNAL'
[Journal]
Storage=volatile
RuntimeMaxUse=50M
ForwardToSyslog=no
JOURNAL
        systemctl restart systemd-journald 2>/dev/null || true
        log "Journal pindah ke RAM (50MB max)"

        info "3/8 — Turunin swappiness..."
        echo "vm.swappiness=10" > /etc/sysctl.d/90-swappiness.conf
        sysctl -w vm.swappiness=10 2>/dev/null || true
        log "Swappiness: 10"

        info "4/8 — IO Scheduler buat SSD..."
        for disk in /sys/block/sd* /sys/block/nvme*; do
            [[ -f "$disk/queue/scheduler" ]] && \
                echo "none" > "$disk/queue/scheduler" 2>/dev/null || true
        done
        cat > /etc/udev/rules.d/60-iosched.rules << 'UDEV'
ACTION=="add|change", KERNEL=="sd*", ATTR{queue/scheduler}="none"
ACTION=="add|change", KERNEL=="nvme*", ATTR{queue/scheduler}="none"
UDEV
        log "IO Scheduler: none (NVMe) / none (SSD)"

        info "5/8 — CPU governor: schedutil..."
        for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            echo "schedutil" > "$cpu" 2>/dev/null || true
        done
        cat > /etc/udev/rules.d/60-cpugovernor.rules << 'CPUFREQ'
ACTION=="add", SUBSYSTEM=="cpu", RUN+="/bin/sh -c 'echo schedutil > /sys/devices/system/cpu/cpu%n/cpufreq/scaling_governor'"
CPUFREQ
        log "CPU Governor: schedutil"

        info "6/8 — Disable NetworkManager (kalo pake static IP)..."
        if systemctl is-active NetworkManager &>/dev/null; then
            warn "NetworkManager aktif. Matikan? (y/N):"
            read -r NM_DISABLE
            if [[ "$NM_DISABLE" =~ ^[Yy]$ ]]; then
                systemctl disable --now NetworkManager 2>/dev/null || true
                log "NetworkManager dimatikan"
            fi
        else
        log "NetworkManager sudah nonaktif"

        info "7/8 — Bersihin cache & package ga kepake..."
        apt-get clean 2>/dev/null || true
        apt-get autoremove --purge -y 2>/dev/null || true
        rm -rf /var/lib/apt/lists/* 2>/dev/null || true
        rm -rf /tmp/* 2>/dev/null || true
        log "Cache & orphans dibersihkan"

        info "8/8 — Disable service ga penting..."
        for svc in cups-browsed cups bluetooth avahi-daemon ModemManager \
                   apt-daily apt-daily-upgrade whoopsie pppd-dns \
                   speech-dispatcher; do
            systemctl disable $svc 2>/dev/null || true
            systemctl mask $svc 2>/dev/null || true
        done
        log "Service ga penting di-mask"

        echo ""
        log "${BOLD}Optimasi selesai! RAM & storage lebih efisien.${NC}"
        info "Reboot disarankan: sudo reboot"
    }

    case "$OPT_CHOICE" in
        1|"") do_optimize_all ;;
        2)
            echo ""
            for opt in \
                "journal persistent -> RAM" \
                "swappiness 10" \
                "IO scheduler none" \
                "CPU governor schedutil" \
                "Matikan NetworkManager" \
                "Bersihin cache" \
                "Disable service ga penting"; do
                ask "Jalankan: $opt? (y/N):"
                read -r ANSWER
                [[ "$ANSWER" =~ ^[Yy]$ ]] && do_optimize_all
            done
            ;;
        *) err "Pilihan tidak valid" ;;
    esac
}

