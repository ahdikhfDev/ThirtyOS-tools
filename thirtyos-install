# ── Helper: Install OpenCode binary langsung dari GitHub ──
cmd_install_opencode_binary() {
    ARCH=$(uname -m)
    case "$ARCH" in
        aarch64|arm64) ARCH_OPENCODE="arm64" ;;
        x86_64|amd64)  ARCH_OPENCODE="amd64" ;;
        armv7l|armhf)  ARCH_OPENCODE="arm" ;;
        *) err "Arsitektur tidak didukung: $ARCH"; return 1 ;;
    esac
    info "Download OpenCode binary untuk ${ARCH}..."
    TMPDIR=/var/tmp
    curl -sL "https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-${ARCH_OPENCODE}.tar.gz" \
        -o /tmp/opencode.tar.gz
    tar -xzf /tmp/opencode.tar.gz -C /tmp/
    mv /tmp/opencode /usr/local/bin/opencode
    chmod +x /usr/local/bin/opencode
    rm -f /tmp/opencode.tar.gz
    if opencode --version &>/dev/null; then
        log "OpenCode: $(opencode --version)"
    else
        err "Gagal install OpenCode binary"
    fi
}

cmd_ai_setup() {
    check_root "ai"
    show_banner
    echo -e "${BOLD}=== AI Service Setup ===${NC}"
    echo ""

    # ── Cek Node.js ──
    info "Mengecek Node.js..."
    if ! command -v node &>/dev/null; then
        warn "Node.js belum ada, install dulu..."
        curl -fsSL https://deb.nodesource.com/setup_20.x | bash - 2>/dev/null || true
        apt-get install -y nodejs 2>/dev/null || true
    fi
    log "Node.js: $(node --version 2>/dev/null || echo 'N/A')"

    # ── Install 9Router ──
    info "Install 9Router..."
    if command -v 9router &>/dev/null; then
        warn "9Router sudah terinstall: $(9router --version 2>/dev/null || echo 'latest')"
        ask "Update 9Router? (Y/n):"
        read -r UPDATE_9R
        if [[ ! "$UPDATE_9R" =~ ^[Nn]$ ]]; then
            npm update -g 9router 2>/dev/null || true
            log "9Router diupdate"
        fi
    else
        npm install -g 9router 2>&1 || err "Gagal install 9Router"
        log "9Router terinstall"
    fi

    # ── Install OpenCode (official binary) ──
    info "Install OpenCode..."
    if opencode --version &>/dev/null; then
        warn "OpenCode sudah terinstall: $(opencode --version 2>/dev/null || echo 'latest')"
        ask "Update OpenCode? (Y/n):"
        read -r UPDATE_OC
        if [[ ! "$UPDATE_OC" =~ ^[Nn]$ ]]; then
            rm -f /usr/local/bin/opencode 2>/dev/null || true
            TMPDIR=/var/tmp curl -fsSL https://opencode.ai/install | bash 2>&1 || \
                cmd_install_opencode_binary
            log "OpenCode diupdate"
        fi
    else
        TMPDIR=/var/tmp curl -fsSL https://opencode.ai/install | bash 2>&1 || \
            cmd_install_opencode_binary
        log "OpenCode terinstall"
    fi

    # ── Config 9Router ──
    info "Konfigurasi 9Router..."
    mkdir -p /root/.9router
    cat > /root/.9router/config.json << 'CFG'
{
  "port": 20128,
  "dashboard": true,
  "fallback": {
    "enabled": true,
    "tiers": ["free", "cheap"],
    "strategy": "auto"
  },
  "providers": {
    "kiro": { "enabled": true, "tier": "free" },
    "opencode-free": { "enabled": true, "tier": "free" },
    "iflow": { "enabled": true, "tier": "free" },
    "qwen": { "enabled": true, "tier": "free" }
  },
  "rtk": {
    "enabled": true,
    "mode": "lossless",
    "target": "tool_result"
  }
}
CFG
    log "9Router dikonfigurasi dengan free providers"

    # ── Buat systemd service untuk 9Router ──
    # Pre-build native modules biar gak compile tiap start
    TMPDIR=/var/tmp npm install -g better-sqlite3 2>&1 || true
    cat > /etc/systemd/system/9router.service << 'SVC9R'
[Unit]
Description=9Router AI Gateway
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/9router
Restart=on-failure
RestartSec=10
User=root
Environment=NODE_ENV=production
Environment=TMPDIR=/var/tmp
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
SVC9R
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable --now 9router 2>/dev/null || true
    log "9Router service aktif"

    # ── Tunggu 9Router jalan ──
    info "Tunggu 9Router siap..."
    sleep 3

    # ── Cek 9Router ──
    if curl -s http://localhost:20128/health >/dev/null 2>&1; then
        log "9Router berjalan di localhost:20128"
    else
        warn "9Router mungkin belum siap, cek: systemctl status 9router"
    fi

    # ── Config OpenCode ──
    info "Konfigurasi OpenCode..."
    OPENCODE_CONFIG_DIR=""
    if [[ -n "$SUDO_USER" ]]; then
        OC_USER_HOME=$(eval echo ~$SUDO_USER)
        OPENCODE_CONFIG_DIR="$OC_USER_HOME/.config/opencode"
    else
        OPENCODE_CONFIG_DIR="$HOME/.config/opencode"
    fi
    mkdir -p "$OPENCODE_CONFIG_DIR"

    # Cek apakah ada opencode.json
    OC_CONFIG="$OPENCODE_CONFIG_DIR/config.json"
    cat > "$OC_CONFIG" << OCCFG
{
  "model": "opencode-free"
}
OCCFG
    chown -R $(stat -c '%u:%g' "$OPENCODE_CONFIG_DIR/.." 2>/dev/null || true) "$OPENCODE_CONFIG_DIR" 2>/dev/null || true
    log "OpenCode dikonfigurasi (model: opencode-free)"

    # ── Info dashboard ──
    echo ""
    log "${BOLD}AI Services siap!${NC}"
    echo -e "  9Router Dashboard : ${CYAN}http://localhost:20128/dashboard${NC}"
    echo -e "  OpenCode CLI      : ${CYAN}opencode${NC}"
    echo ""
    echo -e "  ${YELLOW}Akses dari laptop:${NC}"
    echo -e "  ssh -L 20128:localhost:20128 thirty@<ip-stb>"
    echo -e "  Buka http://localhost:20128/dashboard di browser laptop"
    echo ""
    echo -e "  ${YELLOW}Pertama kali pake OpenCode:${NC}"
    echo -e "  opencode"
    echo ""
}

